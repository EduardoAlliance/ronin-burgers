{
  "expo": {
    "name": "ronin-burgers",
    "slug": "ronin-burgers",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icono-app.png",
    "scheme": "roninburgers",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icono-app.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FF6B00",
        "foregroundImage": "./assets/images/icono-app.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.eduardo87.roninburgers"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
